# Copy this file to backend/.env and edit values.

# Which embeddings backend to use: auto|ollama|openai|none
EMBEDDINGS_PROVIDER=ollama

# Ollama settings
OLLAMA_BASE_URL=http://localhost:11434

# For generating answers (requires you to `ollama pull` the model)
# Example small model:
# OLLAMA_MODEL=llama3.2:3b
OLLAMA_MODEL=qwen2.5:7b

# For semantic retrieval embeddings (use a model you already have from `ollama list`)
OLLAMA_EMBEDDING_MODEL=embeddinggemma:latest

# Optional OpenAI (leave unset for fully-local)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
